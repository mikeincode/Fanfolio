{
  "expo": {
    "name": "Fanfolio",
    "slug": "fanfolio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fanfolio",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C0F14"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.fanfolio.app",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "33d37853-4b07-4ae0-bdf8-4d39fc9d3680"
      }
    },
    "owner": "mikeincode"
  }
}
